# Required — enrichment and triage
VIRUSTOTAL_API_KEY=
ANTHROPIC_API_KEY=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Required — Elasticsearch (pick one approach)
# Option A: set credentials directly
# ELASTIC_PASSWORD=
# ELASTIC_CA_CERT=/path/to/ca.crt

# Option B: point at a local Elastic stack directory (reads .env + certs/ca/ca.crt)
# SIEM_STACK_DIR=/path/to/siem-stack

# Optional enrichment
# ABUSEIPDB_API_KEY=
# ABUSE_CH_AUTH_KEY=

# Optional tuning
# ELASTIC_URL=https://localhost:9200
# ELASTIC_USER=elastic
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# POLL_INTERVAL_SECONDS=60
